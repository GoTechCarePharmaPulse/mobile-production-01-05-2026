{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "staging": {
      "developmentClient": false,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL=https://pharmapulse-backend-rl2h.onrender.com/api"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
	"EXPO_PUBLIC_API_URL=https://pharmapulse-backend-rl2h.onrender.com/api"
        "EXPO_USE_UPDATES": "false"
      }
    }
  }
}